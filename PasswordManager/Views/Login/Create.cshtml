@model PasswordManager.ViewModels.Usuario

@{
    Layout = null;
}
<title>Login</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/login.css"/>

<main class="main-container">
    <!-- Pills navs -->
    <ul class="nav nav-pills nav-justified py-3 gap-3" id="ex1" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-login" data-mdb-pill-init role="tab"
               aria-controls="pills-login" aria-selected="true" asp-controller="Login" asp-action="Index">Login</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link active" id="tab-register" data-mdb-pill-init role="tab"
               aria-controls="pills-register" aria-selected="false" asp-controller="Login" asp-action="Create">Register</a>
        </li>
    </ul>

    <!-- Pills content -->
    <div class="tab-content">
        <!-- Register Form -->
        <div class="tab-pane fade show active" id="pills-register" role="tabpanel" aria-labelledby="tab-register">
            <form asp-controller="Login" asp-action="Create" method="post">
                <!-- Name input -->
                <div data-mdb-input-init class="form-outline mb-4">
                    <input type="text" id="registerName" class="form-control" asp-for="Nombre" />
                    <label class="form-label" for="registerName">Usuario</label>
                </div>

                <!-- Email input -->
                <div data-mdb-input-init class="form-outline mb-4">
                    <input type="email" id="registerEmail" class="form-control" asp-for="Correo" />
                    <label class="form-label" for="registerEmail">Email</label>
                </div>

                <!-- Password input -->
                <div data-mdb-input-init class="form-outline mb-4">
                    <input type="password" id="registerPassword" class="form-control" asp-for="Clave" />
                    <label class="form-label" for="registerPassword">Password</label>
                </div>

                <!-- Repeat Password input -->
                <div data-mdb-input-init class="form-outline mb-4">
                    <input type="password" id="registerRepeatPassword" class="form-control" asp-for="ConfirClave" />
                    <label class="form-label" for="registerRepeatPassword">Repeat password</label>
                </div>

                <!-- Submit button -->
                <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-block mb-3 w-100">Sign in</button>

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-warning text-center" role="alert">
                        @TempData["Mensaje"]
                     </div>
                }

            </form>
        </div>
    </div>

</main>